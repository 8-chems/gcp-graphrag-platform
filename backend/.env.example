ENVIRONMENT=development
PROJECT_ID=your-gcp-project
REGION=europe-west1
CORS_ORIGINS=http://localhost:5173

VERTEX_LOCATION=europe-west1
GEMINI_MODEL=gemini-1.5-pro-002
EMBEDDING_MODEL=text-embedding-004

SQL_HOST=localhost
SQL_PORT=5432
SQL_DB=app_db
SQL_USER=app_user
SQL_PASSWORD=local_dev_password

BQ_DATASET=graphrag
BQ_VECTOR_TABLE=document_embeddings

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=local_dev_password

GCS_BUCKET=your-project-documents
FIREBASE_PROJECT_ID=your-gcp-project

# Comma-separated bootstrap admin allowlist (used only if a user has no
# `admin` custom claim yet). Prefer scripts/set_admin_claim.py once you have
# at least one admin set up.
ADMIN_EMAILS=you@example.com
