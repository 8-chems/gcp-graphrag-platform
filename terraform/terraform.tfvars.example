project_id = "your-gcp-project"
region     = "europe-west1"
environment = "dev"

neo4j_uri      = "neo4j+s://xxxxx.databases.neo4j.io"
neo4j_user     = "neo4j"
neo4j_password = "change-me"

github_repo = "your-org/your-repo"

# Must match -backend-config bucket and GitHub secret TF_STATE_BUCKET (NOT the documents bucket).
tf_state_bucket_name = "your-gcp-project-graphrag-platform-tfstate"

# From Firebase console → Project settings (may differ from GCP project_id).
firebase_project_id = "your-gcp-project-d3260"